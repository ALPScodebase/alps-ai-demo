# --- BLOCKCHAIN ---
# RPC URL to connect to hardhat blockchain (Internal address to get in docker)
CHAIN_RPC_URL=http://chain:8545
CHAIN_ID=31337

# --- PORT AND SERVICES ---
BOOTSTRAP_PORT=19900
QUEUE_PORT=20000
ORACLE_P2P_PORT=20010

# --- DOCKER INTERNAL ADDRESSES ---
BOOTSTRAP_ADDR=bootstrap:19900
QUEUE_URL=http://queue:20000

# IPFS Configuration (Client -> Docker)
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080
DOCKER_IPFS_URL=http://ipfs:5001

# Number of Oracles for the Verifier deployment, modify it
NUM_ORACLES=4

# --- MAIN CONTRACT ADDRESS ---
AGGREGATOR_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_token_goes_here